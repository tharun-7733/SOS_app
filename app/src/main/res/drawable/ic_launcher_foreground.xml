<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — RL monogram in white.
    Canvas is 108×108dp; the safe zone (always visible) is the centre 72×72dp.
    All path data is scaled to sit comfortably within the safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White RL serif monogram, centred on the 108×108 canvas -->
    <group
        android:translateX="22"
        android:translateY="18"
        android:scaleX="0.6"
        android:scaleY="0.6">

        <!--
            R glyph  (roughly 0,0 → 40,72)
            Stem, bowl, and leg drawn as a filled path.
        -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
M 8,0
L 8,72
L 0,72
L 0,0
Z

M 8,0
L 28,0
Q 50,0 50,22
Q 50,38 36,42
L 54,72
L 44,72
L 27,43
L 8,43
L 8,36
L 28,36
Q 42,36 42,22
Q 42,8 28,8
L 8,8
Z
            " />

        <!--
            L glyph  (roughly 52,0 → 86,72)
            Vertical stem + bottom horizontal bar.
        -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
M 58,0
L 66,0
L 66,64
L 90,64
L 90,72
L 58,72
Z
            " />
    </group>
</vector>